APP_NAME=megadoc
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE_BYTES=52428800
DEDUPLICATE_BY_HASH=true
DATABASE_URL=postgresql+psycopg://megadoc:megadoc@postgres:5432/megadoc
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TASK_ALWAYS_EAGER=false
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_RAW=raw-documents
S3_BUCKET_DERIVATIVES=derived-documents
S3_REGION=us-east-1
STORAGE_BACKEND=s3
LOCAL_STORAGE_PATH=/tmp/megadoc-storage
OCR_BACKEND=docling
OCR_ACCELERATOR_DEVICE=auto
OCR_ACCELERATOR_NUM_THREADS=4
OCR_RAPIDOCR_BACKEND=torch
PIPELINE_VERSION=v1
REQUEST_TIMEOUT_SECONDS=30
API_BASE_URL=http://api:8080
WORKER_INSTALL_PADDLE_OCR=false
ROTATION_DETECTOR_BACKEND=none
ROTATION_DETECTOR_MODEL_ID=
ROTATION_DETECTOR_MIN_CONFIDENCE=0.80
ROTATION_DETECTOR_SAMPLE_PAGES=4
ROTATION_DETECTOR_MIN_CONSENSUS=0.75
OCR_REFINEMENT_ENABLED=false
OCR_REFINEMENT_ENDPOINT=http://10.89.0.3:8080/v1
OCR_REFINEMENT_MODEL=qwen3.6-A3B
OCR_REFINEMENT_API_KEY=
OCR_REFINEMENT_TIMEOUT=180
OCR_REFINEMENT_MAX_TOKENS=2048
OCR_REFINEMENT_MAX_PAGES=3
OCR_REFINEMENT_MIN_PAGE_SCORE=0.35
OCR_REFINEMENT_PROMOTE_TEXT=false

# Knowledge Classifier Configuration
KN_LLM_ENDPOINT=http://10.89.0.3:8080/v1
KN_LLM_MODEL=qwen3.5-27B
KN_LLM_API_KEY=
KN_LLM_TIMEOUT=120
KN_LLM_TEMPERATURE=0.1
KN_LLM_MAX_RETRIES=3
KN_CONFIDENCE_THRESHOLD_SEGMENTATION=0.7
KN_CONFIDENCE_THRESHOLD_CLASSIFICATION=0.7
KN_CONFIDENCE_THRESHOLD_TOPIC=0.6
KN_MAX_TOPICS_TO_RETRIEVE=10
